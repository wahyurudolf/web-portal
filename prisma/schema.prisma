// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabel Utama: Daftar Aplikasi Portal
model Application {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String

  // --- Konfigurasi Ikon Baru ---
  iconType    String   @default("SVG") // Pilihan: "SVG" atau "IMAGE"
  iconValue   String?  // Berisi teks <svg>...</svg> ATAU data URL base64 gambar 

  // --- Relasi Kategori (One-to-Many) ---
  // Satu aplikasi hanya punya 1 kategori, tapi 1 kategori bisa punya banyak aplikasi
  categories  Category[]

  // --- Relasi Divisi (Many-to-Many) ---
  divisions   Division[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel Master: Daftar Kategori (Baru)
model Category {
  id          String        @id @default(cuid())
  name        String        @unique // Contoh: "Operasional", "IT"
  
  apps        Application[]
}

// Tabel Master: Daftar Divisi/Bagian
model Division {
  id          String        @id @default(cuid())
  name        String        @unique // Contoh: "Rendiklat", "Pemeliharaan"
  
  apps        Application[]
}
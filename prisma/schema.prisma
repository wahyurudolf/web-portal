// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// Menggunakan SQLite untuk pengembangan lokal yang cepat
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabel Utama: Daftar Aplikasi Portal
model Application {
  id          String   @id @default(cuid())
  name        String   // Nama aplikasi (Contoh: Sistem Manajemen Aset)
  description String?  // Deskripsi opsional
  url         String   // Link URL tujuan web
  icon        String?  // Nama ikon (opsional, misal "wrench", "users")

  // --- Konfigurasi Tampilan Card ---
  bgType      String   @default("COLOR") // Pilihan: "COLOR" atau "IMAGE"
  bgValue     String   // Berisi kode Hex (misal: #ffffff) ATAU path gambar (/uploads/bg-1.jpg)
  textColor   String   @default("DARK")  // Pilihan: "LIGHT" (putih) atau "DARK" (hitam/gelap)

  // --- Relasi Lintas Divisi (Many-to-Many) ---
  // Satu aplikasi bisa digunakan banyak divisi, satu divisi bisa punya banyak aplikasi
  divisions   Division[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel Master: Daftar Divisi/Bagian
model Division {
  id          String        @id @default(cuid())
  name        String        @unique // Contoh: "Operasional", "IT", "SDM", "Keuangan"
  
  // Relasi balik ke tabel Aplikasi
  apps        Application[]
}